rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      // User can read everything (images, etc.)
      allow read: if true;
      
      // User can only write to their own folder (e.g., profiles, job_images)
      allow write: if request.auth != null;
    }
  }
}
